# Senhub サーバー設定ファイル
# このファイルを .env にコピーして編集してください
#   cp .env.example .env

# ------------------------------------------------------------------
# ネットワーク設定
# ------------------------------------------------------------------

# バインドアドレス（通常は変更不要）
SENHUB_HOST=0.0.0.0

# 公開ドメイン名（TLS証明書のパス生成にも使用）
SENHUB_DOMAIN=senhub.hide.link

# ポート番号
# TLS有効時は 443、無効時（社内LAN・開発）は 8000 が一般的
SENHUB_PORT=443

# ------------------------------------------------------------------
# TLS 設定
# ------------------------------------------------------------------

# TLS（HTTPS）を使用するか
# 本番: true / 社内LAN・ローカル開発: false
SENHUB_USE_TLS=true

# TLS証明書・秘密鍵のパス（USE_TLS=true の場合のみ参照）
# Let's Encrypt を使う場合はデフォルト値のまま DOMAIN を変更するだけでOK
# SENHUB_TLS_CERT=/etc/letsencrypt/live/senhub.hide.link/fullchain.pem
# SENHUB_TLS_KEY=/etc/letsencrypt/live/senhub.hide.link/privkey.pem

# ------------------------------------------------------------------
# API 設定
# ------------------------------------------------------------------

# メモリ上の最大保持件数（DB実装後は不要）
SENHUB_MAX_RECORDS=10000

# デフォルトの認証キー（本番では必ず変更すること）
SENHUB_DEFAULT_WRITE_KEY=test_writeKey
SENHUB_DEFAULT_READ_KEY=test_readKey


# ------------------------------------------------------------------
# 設定例: ケース別
# ------------------------------------------------------------------

# ── ① 本番（senhub.hide.link, HTTPS 443番） ──
# SENHUB_DOMAIN=senhub.hide.link
# SENHUB_PORT=443
# SENHUB_USE_TLS=true

# ── ② 別ドメイン（myserver.example.com, HTTPS 8443番） ──
# SENHUB_DOMAIN=myserver.example.com
# SENHUB_PORT=8443
# SENHUB_USE_TLS=true
# SENHUB_TLS_CERT=/etc/letsencrypt/live/myserver.example.com/fullchain.pem
# SENHUB_TLS_KEY=/etc/letsencrypt/live/myserver.example.com/privkey.pem

# ── ③ 社内LAN（IPアドレス直打ち, HTTP 8000番） ──
# SENHUB_DOMAIN=192.168.1.100
# SENHUB_PORT=8000
# SENHUB_USE_TLS=false

# ── ④ ローカル開発（localhost, HTTP 8000番） ──
# SENHUB_DOMAIN=localhost
# SENHUB_PORT=8000
# SENHUB_USE_TLS=false


# ------------------------------------------------------------------
# DB 設定（TimescaleDB / PostgreSQL）
# ------------------------------------------------------------------

# TimescaleDB 接続URL（設定するとDBモードで起動。未設定はメモリモード）
# 形式: postgresql://<user>:<password>@<host>:<port>/<database>
# SENHUB_DB_URL=postgresql://senhub:senhubpass@localhost:5432/senhub

# コネクションプールサイズ（通常は変更不要）
# SENHUB_DB_POOL_MIN=2
# SENHUB_DB_POOL_MAX=10

# ------------------------------------------------------------------
# DB セットアップ手順
# ------------------------------------------------------------------
# 1. TimescaleDB + PostgreSQL をインストール
#    https://docs.timescale.com/self-hosted/latest/install/
#
# 2. DB・ユーザーを作成（postgres ユーザーで実行）:
#    sudo -u postgres bash scripts/setup-db.sh
#
# 3. スキーマを適用（上記スクリプトが自動実行）:
#    psql -d senhub -U senhub -f server/schema.sql
#
# 4. .env に SENHUB_DB_URL を設定してサーバー起動:
#    SENHUB_DB_URL=postgresql://senhub:senhubpass@localhost:5432/senhub python server/main.py
