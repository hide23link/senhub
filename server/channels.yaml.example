# Senhub チャンネル管理ファイル
# ============================================================
# 最大 100 チャンネルまで登録可能
#
# 新規チャンネルのキー生成:
#   python scripts/gen-channel-keys.py <channel_id> [チャンネル名]
#
# このファイル（channels.yaml）は秘密鍵を含むため .gitignore で除外済み。
# このテンプレート（channels.yaml.example）のみ git で管理する。
# ============================================================

channels:

  # ---- テスト用チャンネル ----
  100:
    name: "テストチャンネル"
    write_key: "test_writeKey"
    read_key:  "test_readKey"

  # ---- 本番チャンネル例（gen-channel-keys.py で生成） ----
