# =============================================================================
# Senhub インストール設定ファイル
#
# 使い方:
#   1. このファイルを同じディレクトリに "install.conf" としてコピー
#      cp install.conf.example install.conf
#
#   2. 必要な値を編集
#
#   3. スクリプトを引数なしで実行
#      bash install-local.sh          # 構成A（Docker Compose）
#      bash install-production.sh     # 構成B（ベアメタル）
#
# 注意:
#   - install.conf は .gitignore に登録済み（IPアドレス等を含むため Git に入れない）
#   - 環境変数が設定されている場合は install.conf より環境変数が優先される
#   - コメントアウト（#）した項目はデフォルト値が使用される
# =============================================================================

# -----------------------------------------------------------------------------
# 共通設定（install-local.sh / install-production.sh 両方で使用）
# -----------------------------------------------------------------------------

# サーバーのIPアドレスまたはドメイン名
# 例（IP）:     SERVER_DOMAIN="192.168.1.100"
# 例（ドメイン）: SERVER_DOMAIN="senhub.example.com"
SERVER_DOMAIN=""

# -----------------------------------------------------------------------------
# 構成B 専用設定（install-production.sh のみ使用）
# -----------------------------------------------------------------------------

# HTTPS（TLS）を使用するか: true / false
# true  → Let's Encrypt で証明書を自動取得（SERVER_DOMAIN がドメイン名の場合のみ）
# false → HTTP のみ（社内 LAN や IP アドレス運用時）
USE_TLS="false"

# Let's Encrypt 用メールアドレス（USE_TLS=true の場合のみ必要）
# 未設定の場合は証明書取得をスキップして HTTP で起動します
# 例: LE_EMAIL="admin@example.com"
LE_EMAIL=""

# リッスンポート（省略時は自動設定: USE_TLS=true → 443, false → 8000）
# 例: SERVER_PORT="8443"
SERVER_PORT=""
