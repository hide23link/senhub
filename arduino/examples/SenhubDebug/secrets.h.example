#pragma once
// ============================================================
//  Senhub デバッグスケッチ — 秘密情報ファイル
// ============================================================
//  【使い方】
//  1. このファイルを secrets.h という名前でコピーする
//       cp secrets.h.example secrets.h
//  2. 下記の値を実際の WiFi 情報・チャンネルキーに書き換える
//  3. secrets.h は .gitignore で Git から除外済み
//     → WiFi パスワード・write_key を誤って公開しない
// ============================================================

// WiFi 認証情報
#define WIFI_SSID     "YOUR_SSID"
#define WIFI_PASS     "YOUR_PASSWORD"

// Senhub チャンネル設定（channels.yaml の値に合わせる）
#define WRITE_KEY     "test_writeKey"
#define SERVER_URL    "http://192.168.11.85:8000/api/v1"
#define CHANNEL_ID    100
